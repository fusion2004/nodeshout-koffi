{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major dependencies",
      "groupSlug": "non-major"
    },
    {
      "matchManagers": ["mise"],
      "matchDepNames": ["node"],
      "enabled": false
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "matchDepNames": ["node"],
      "enabled": false
    }
  ],
  "rangeStrategy": "bump"
}
